#!/bin/bash
# G5 Pre-Deploy Check — 自動產生，勿手動修改
# Hook Type: PreToolUse (Bash) — Pre-Deploy Typecheck & Build Gate
# Generated by AgentHub HookManager
# Hash: {{GENERATED_HASH}}

INPUT=$(cat)

# Extract command — use jq if available, otherwise grep fallback (Windows Git Bash)
if command -v jq &>/dev/null; then
  TOOL=$(echo "$INPUT" | jq -r '.tool_name // ""')
  [ "$TOOL" != "Bash" ] && exit 0
  CMD=$(echo "$INPUT" | jq -r '.tool_input.command // ""')
else
  echo "$INPUT" | grep -q '"tool_name".*"Bash"' || exit 0
  CMD=$(echo "$INPUT" | sed -n 's/.*"command"\s*:\s*"\([^"]*\)".*/\1/p')
fi

# Check if command contains deploy-related keywords
if ! echo "$CMD" | grep -qiE 'deploy|publish|release|npm publish|docker push'; then
  exit 0
fi

# Deploy command detected — run typecheck and build
cd "{{PROJECT_DIR}}"

echo "G5 Pre-Deploy: running typecheck..."
{{TYPECHECK_COMMAND}} 2>&1
TYPECHECK_EXIT=$?

echo "G5 Pre-Deploy: running build..."
{{BUILD_COMMAND}} 2>&1
BUILD_EXIT=$?

if [ $TYPECHECK_EXIT -ne 0 ] || [ $BUILD_EXIT -ne 0 ]; then
  echo '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"G5 Pre-Deploy: typecheck 或 build 失敗，請修復後再部署"}}'
  exit 0
fi

exit 0
