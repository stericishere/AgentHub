#!/bin/bash
# Stop Validator — 自動產生，勿手動修改
# Generated by AgentHub HookManager
# Hash: {{GENERATED_HASH}}

log_hook() {
  local RESULT="$1" REASON="$2"
  mkdir -p "{{PROJECT_DIR}}/.claude" 2>/dev/null
  echo "{\"hook\":\"stop-validator\",\"type\":\"Stop\",\"result\":\"${RESULT}\",\"reason\":\"${REASON}\",\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo unknown)\"}" >> "{{PROJECT_DIR}}/.claude/hook-execution.jsonl"
}

INPUT=$(cat)

# Extract stop_hook_active — use jq if available, otherwise grep fallback (Windows Git Bash)
if command -v jq &>/dev/null; then
  STOP_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false')
else
  STOP_ACTIVE=$(echo "$INPUT" | sed -n 's/.*"stop_hook_active"\s*:\s*\(true\|false\).*/\1/p')
  [ -z "$STOP_ACTIVE" ] && STOP_ACTIVE="false"
fi
if [ "$STOP_ACTIVE" = "true" ]; then exit 0; fi

cd "{{PROJECT_DIR}}"

# G3: Check test file existence
TEST_FILES=$(find . -maxdepth 4 -name "*.test.ts" -o -name "*.spec.ts" -o -name "*.test.js" -o -name "*.spec.js" 2>/dev/null | head -5)
if [ -z "$TEST_FILES" ]; then
  echo "⚠️ G3 Warning: No test files found in project"
fi

echo "🔍 Running tests..."
{{TEST_COMMAND}} 2>&1
TEST_EXIT=$?

echo "🔍 Running lint..."
{{LINT_COMMAND}} 2>&1
LINT_EXIT=$?

if [ $TEST_EXIT -ne 0 ] || [ $LINT_EXIT -ne 0 ]; then
  log_hook "blocked" "tests or lint failed"
  echo '{"continue": false, "stopReason": "Stop Validator: tests or lint failed. Fix issues before ending session."}'
  exit 0
fi

log_hook "passed" "all checks passed"
echo '{"continue": true}'
exit 0
